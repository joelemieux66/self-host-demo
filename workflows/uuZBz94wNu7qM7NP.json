      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        440,
        0
      ],
      "parameters": {
        "promptType": "define",
        "text": "=You are an SDR sending a SHORT follow-up in an email sequence on behalf of n8n (a workflow-automation platform). Today is {{ $now.format('yyyy-MM-dd') }}.\n\nRecipient: {{ $json.contactName }} ({{ $json.contactRole }}) at {{ $json.company }}\nThis is follow-up number {{ $json.step + 1 }} in the sequence (1 = a brief, friendly bump referencing your first email; 2 = a final polite breakup / closing-the-loop email, a no-pressure last attempt).\nThe original email subject was: {{ $json.lastSubject }}\n\nWrite 40-80 words, warm and low-pressure, with one clear soft CTA (a quick 15-minute call). Do not repeat the original email; add a light new angle or gentle nudge.\n\nFormat your response EXACTLY as:\nSubject: <subject line>\n\n<the email body>\n\nClose with EXACTLY this signature:\nBest,\nJoe Lemieux\nSolutions Engineer, n8n\n\nFor follow-up 1 use the subject \"Re: {{ $json.lastSubject }}\". For follow-up 2 use a subject like \"Closing the loop\".",
        "batching": {}
      }
    },
    {
      "id": "p0000000-0000-4000-8000-000000000004",
      "name": "Advance",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
