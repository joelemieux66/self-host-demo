        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "status": "awaiting_approval",
            "step": "={{ $('Get due').item.json.step + 1 }}",
            "lastSubject": "={{ $('Compose step').item.json.text.split('\\n')[0].replace('Subject:','').trim() }}"
          }
        }
      }
    },
