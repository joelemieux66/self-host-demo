      "position": [
        880,
        0
      ],
      "parameters": {
        "inputText": "={{ $('Parse reply').item.json.replyText }}",
        "categories": {
          "categories": [
            {
              "category": "interested",
              "description": "The prospect shows interest, asks a question, wants more information, or wants to book a meeting or call."
            },
            {
              "category": "not_interested",
              "description": "The prospect declines: not interested, not a fit, not now, no thanks, or already has a solution."
            },
            {
              "category": "out_of_office",
              "description": "An automatic out-of-office, vacation, or auto-reply indicating the person is temporarily away."
            },
            {
              "category": "unsubscribe",
              "description": "The prospect asks to stop emailing them, opt out, unsubscribe, or remove them from the list."
            }
          ]
        },
        "options": {
          "enableAutoFixing": true,
          "fallback": "other"
        }
      }
    },
