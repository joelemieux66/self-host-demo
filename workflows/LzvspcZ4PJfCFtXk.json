      "position": [
        220,
        0
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "pr1",
              "name": "senderEmail",
              "value": "={{ (($json.from || '').toString().match(/[\\w.+-]+@[\\w.-]+\\.[\\w-]+/) || [''])[0].toLowerCase() }}",
              "type": "string"
            },
            {
              "id": "pr2",
              "name": "replyText",
              "value": "={{ $json.text || $json.snippet || $json.subject || '' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
