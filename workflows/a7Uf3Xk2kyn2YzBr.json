    {
      "parameters": {
        "jsCode": "const NL = String.fromCharCode(10);\nconst company = $('Workflow Input').item.json.company || 'the company';\nconst merged = $('Merge research + KB').item.json;\nconst research = merged.research || '';\nconst extract = (arr) => (Array.isArray(arr) ? arr : []).map(d => (d && ((d.document && d.document.pageContent) || d.pageContent)) || '').filter(Boolean);\nconst kbN8n = extract(merged.kb_n8n);\n\nlet a = {};\ntry { a = JSON.parse(String($input.first().json.text || '').split('```json').join('').split('```').join('').trim()); } catch (e) { a = {}; }\nconst hasScore = typeof a.score === 'number' && isFinite(a.score);\nconst score = hasScore ? Math.max(0, Math.min(100, Math.round(a.score))) : null;\nconst tier = a.tier || (score == null ? 'N/A' : (score >= 80 ? 'A' : score >= 60 ? 'B' : score >= 40 ? 'C' : 'D'));\nconst signals = Array.isArray(a.signals) ? a.signals : [];\nconst opportunities = Array.isArray(a.opportunities) ? a.opportunities : [];\nconst rationale = a.rationale || '';\n\nconst parts = [];\nparts.push('# Prospect Brief: ' + company);\nparts.push('');\nparts.push('**Automation-readiness score:** ' + (score == null ? 'N/A' : (score + '/100')) + ' (Tier ' + tier + ')');\nparts.push('');\nparts.push('## Research');\nparts.push(research || 'No research available.');\nparts.push('');\nparts.push('## Automation-Readiness Assessment');\nif (rationale) { parts.push(rationale); parts.push(''); }\nif (signals.length) { parts.push('**Why ' + company + ' fits n8n**'); signals.forEach(s => parts.push('- ' + s)); parts.push(''); }\nif (opportunities.length) { parts.push('**Where n8n could help ' + company + '**'); opportunities.forEach(s => parts.push('- ' + s)); parts.push(''); }\nconst brief = parts.join(NL);\n\nreturn [{ json: { company, automation_readiness_score: score, tier, kb_matches: kbN8n.length, enriched_brief: brief } }];"
      },
